# ── Server ───────────────────────────────────────────────────────────────────
PORT=3002

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Full connection string used by the pg Pool.
# When running via Docker Compose this is pre-configured in docker-compose.yml.
# For local development, point at your local Postgres instance.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/case_db

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
# AMQP connection URL.
# Default credentials for the bundled Docker container are guest/guest.
RABBITMQ_URL=amqp://localhost:5672
