# ─── API Gateway Configuration ─────────────────────────────────────────────

# Server
PORT=3000

# ─── Downstream Services ───────────────────────────────────────────────────
# These URLs point to the other services.  In Docker Compose the container
# names are used as hostnames.  For local development use localhost with the
# appropriate port.

AUTH_SERVICE_URL=http://authentication-service:3001
VIOLATION_SERVICE_URL=http://violation-analysis-service:3002

# ─── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000        # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100        # max requests per window per IP

# ─── File Upload ───────────────────────────────────────────────────────────
MAX_IMAGE_SIZE=10485760            # 10 MB in bytes
