# SnapPark Environment Configuration

## Development Environment

# API Gateway
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Services Configuration
AUTH_SERVICE_URL=http://localhost:3001
VIOLATION_SERVICE_URL=http://localhost:3002
NOTIFICATION_SERVICE_URL=http://localhost:3004

# Database Configuration
DATABASE_URL=postgresql://snappark_user:snappark_password@localhost:5432/snappark_auth
CASE_DB_URL=postgresql://snappark_user:snappark_password@localhost:5433/snappark_case
NOTIFICATION_DB_URL=postgresql://snappark_user:snappark_password@localhost:5434/snappark_notifications
AUDIT_DB_URL=postgresql://snappark_user:snappark_password@localhost:5435/snappark_audit

# Message Broker
MESSAGE_BROKER_URL=amqp://guest:guest@localhost:5672

# Security
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRY=15m
PASSWORD_SALT_ROUNDS=10

# External APIs
GEMINI_API_KEY=dev-api-key-here
GEMINI_API_URL=https://api.gemini.google.com

# Notification Service — SMS (Twilio)
TWILIO_ACCOUNT_SID=dev-account-sid
TWILIO_AUTH_TOKEN=dev-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Notification Service — Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@snappark.app

# Notification Service — Push (Firebase Cloud Messaging)
FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json

# File Upload
IMAGE_UPLOAD_DIR=/uploads/images
MAX_IMAGE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# Retry Configuration
RETRY_ATTEMPTS=3
RETRY_DELAY=1000

# Timeouts
API_TIMEOUT=30000
DB_TIMEOUT=5000
GEMINI_TIMEOUT=10000

# Feature Flags
ENABLE_EVENT_SOURCING=true
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
